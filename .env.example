# ── websim AI agent secrets ──
# NEVER commit this file. Copy it to .env and fill in your values.

# ── API Provider (OpenAI-compatible) ──
# Point this at any OpenAI-compatible endpoint that supports tool/function calling.
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=your-model-id

# Does your endpoint support image/vision input?
# true  = agent can analyze screenshots of websim projects
# false = text-only mode
OPENAI_VISION_SUPPORT=false

# ── websim auth ──
# Preferred: install the official CLI and run `websim-cli login`.
# This agent will automatically read ~/.websim-cli.json when WEBSIM_BEARER is blank.
# Optional fallback: paste a Websim bearer/JWT here if you cannot use websim-cli login.
WEBSIM_BEARER=
# Optional: custom path to the official CLI auth file.
# WEBSIM_CLI_CONFIG=/path/to/.websim-cli.json

# The bot's OWN websim username — used to skip its own comments so it doesn't
# reply to itself in a loop. MUST match the account used by WEBSIM_BEARER or
# `websim-cli login`.
WEBSIM_BOT_USERNAME=YourBotUsername
# Comma-separated usernames allowed to run admin commands.
WEBSIM_ADMIN_USERNAMES=Endoxidev

# ── Agent settings ──
# Max tool-calling loop iterations (prevents infinite loops)
AGENT_MAX_TURNS=15
# Daemon polling interval in seconds (10 = check every 10s)
AGENT_WATCH_INTERVAL_SECONDS=10
# Auto-prune state entries older than this many days
AGENT_STATE_MAX_AGE_DAYS=90
# Extra verbose logging
AGENT_DEBUG=false
# Public !status command rate limit per username, in seconds.
AGENT_STATUS_RATE_LIMIT_SECONDS=60

# ── Safety / media moderation ──
# The agent keeps content teen-friendly for a 13+ platform.
# Image/video URLs in comments and uploaded files are scanned when possible.
WEBSIM_MEDIA_MODERATION=true
WEBSIM_MEDIA_MODERATION_ENDPOINT=https://imgcheck.val.run
# Blocks Sexy/Porn/Hentai classifications at or above this probability.
WEBSIM_MEDIA_MODERATION_THRESHOLD=0.55
# For video URLs, sample this many frames with ffmpeg and block if >50% are unsafe.
WEBSIM_VIDEO_MODERATION_FRAMES=5
# Local/remote media guardrails: 500MB max, 30 minutes max for videos.
WEBSIM_MAX_MEDIA_BYTES=524288000
WEBSIM_MAX_VIDEO_SECONDS=1800
# Delete stale local project mirror files older than this many hours.
WEBSIM_PROJECT_CACHE_MAX_AGE_HOURS=24
